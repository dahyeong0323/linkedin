APP_ENV=local
# Required: replace with a strong random local secret before connecting LinkedIn.
# Stored OAuth tokens cannot be decrypted if this value changes later.
APP_SECRET_KEY=replace_with_a_strong_random_secret
DATABASE_URL=sqlite:///./data/app.db

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback
LINKEDIN_SCOPES=openid profile w_member_social
LINKEDIN_MEMBER_URN=
LINKEDIN_API_VERSION=202605

OPENAI_API_KEY=
WRITING_SKILL_PATH=../linkedin-style-writer-skill
